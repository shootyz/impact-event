# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Never expose this client-side

# App
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Admin authentication (single shared secret — use a long random string)
ADMIN_PASSWORD=change-me-use-a-long-random-string

# Cron authentication (Vercel injects this automatically for cron jobs)
CRON_SECRET=change-me-use-a-long-random-string

# Email (Resend)
RESEND_API_KEY=re_your_key
RESEND_FROM_EMAIL=events@yourdomain.ch
ADMIN_NOTIFICATION_EMAIL=info@impactgstaad.ch

# Apple Wallet (optional)
APPLE_PASS_TYPE_IDENTIFIER=
APPLE_TEAM_IDENTIFIER=
APPLE_PASS_CERT_B64=
APPLE_PASS_CERT_PASSWORD=
APPLE_WWDR_CERT_B64=
